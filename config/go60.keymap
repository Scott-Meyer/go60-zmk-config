/*
 * Go60 keymap ported from ZSA Voyager layout (Oryx hashId zLQWY4 / "ben-vallack-qwerty-more-left")
 *
 * Main 4x6-per-half grid is a direct 1:1 port of the Voyager layers, including
 * home-row mods, layer-taps, and the custom dual-function bracket/punctuation keys.
 *
 * The Go60 has 6 extra keys per half beyond the main grid (an upper row of 3 and a
 * thumb row of 3). The Voyager has no equivalent to the upper row, so it is &none
 * on every layer. Of the thumb row, only the two innermost keys carry the Voyager
 * thumb functions (left: the "shift"-labeled key = Voyager's tap-Space/hold-Hyper key,
 * the "control"-labeled key = Voyager's Left Shift; right: the "alt"-labeled key =
 * Voyager's Mouse Button 1, the "space"-labeled key = Voyager's Right GUI). The
 * remaining thumb key on each half (left "up arrow", right "enter") is &none.
 *
 * DRAG_SCROLL from your Navigator trackball is reworked as a hold-to-scroll key
 * (the left half's spare "up arrow" thumb slot) that scopes the RIGHT trackpad
 * (your primary pointing hand) into scroll mode via input-processors, ZMK's
 * native equivalent -- see the &cirque_rh_listener override at the bottom.
 * The Navigator's CPI inc/dec keys have no equivalent (Go60's trackpad
 * sensitivity is a fixed build-time scaler, not runtime-adjustable) and are
 * left as &none on layer 5. RGB "mode forward" is approximated with
 * &rgb_ug RGB_EFF.
 */

#include <behaviors.dtsi>

#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/rgb.h>
#include <input/processors.dtsi>

// layers (same numbering as the Voyager source, for easy cross-reference)
#define LAYER_Base      0
#define LAYER_Media     1
#define LAYER_Sym       2
#define LAYER_Sym2      3
#define LAYER_FKeys     4
#define LAYER_Mouse     5
#define LAYER_Scroll    6

/ {
    behaviors {
        // Generic tap/hold pair: &ht <hold-binding> <tap-binding>
        ht: hold_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };

        caps_word: caps_word {
            compatible = "zmk,behavior-caps-word";
            #binding-cells = <0>;
            continue-list = <UNDERSCORE MINUS>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        layer_Base {
            bindings = <
     &kp GRAVE  &kp N1              &kp N2              &kp N3              &kp N4              &kp N5                                                        &kp N6  &kp N7              &kp N8              &kp N9              &kp N0    &none
      &kp TAB   &kp Q               &mt LCTRL W         &mt LALT E          &mt LGUI R          &kp T                                                         &kp Y   &mt RGUI U          &mt RALT I          &mt RCTRL O         &kp P     &none
      &kp ESC   &lt LAYER_FKeys A   &lt LAYER_Sym2 S    &lt LAYER_Sym D     &lt LAYER_Media F   &lt LAYER_Mouse G                                             &lt LAYER_Mouse H  &lt LAYER_Media J   &lt LAYER_Sym K     &lt LAYER_Sym2 L    &lt LAYER_FKeys SEMI  &kp SQT
   &caps_word   &kp Z               &kp X               &kp C               &kp V               &kp B                                                         &kp N   &kp M               &kp COMMA           &kp DOT             &kp FSLH  &none
                                        &none  &none  &none                                                                                                                     &none  &none  &none
                                                     &mo LAYER_Scroll  &ht LS(LC(LG(LALT))) SPACE  &kp LSHFT              &mkp LCLK  &kp RGUI  &none
            >;
        };

        layer_Media {
            bindings = <
    &kp C_VOL_UP    &trans  &trans  &trans  &trans  &trans                                              &trans  &kp C_PREV  &kp C_NEXT  &kp C_PP  &kp C_STOP  &trans
    &kp C_VOL_DN    &trans  &kp LC(LS(TAB))  &kp LC(TAB)  &trans  &trans                                 &trans  &trans  &kp UP  &kp BSPC  &trans  &trans
    &kp C_PP        &kp DEL  &trans  &none  &trans  &kp LG(LC(LS(N4)))                                  &trans  &kp LEFT  &kp DOWN  &kp RIGHT  &kp RET  &trans
    &kp C_PREV      &kp C_NEXT  &kp LG(X)  &kp LG(C)  &kp LG(V)  &trans                                  &trans  &trans  &trans  &trans  &trans  &rgb_ug RGB_EFF
                                        &none  &none  &none                                                                                                     &none  &none  &none
                                                     &trans  &mkp LCLK  &mkp RCLK              &mkp LCLK  &mkp RCLK  &none
            >;
        };

        layer_Sym {
            bindings = <
    &trans  &trans  &trans  &trans  &trans  &trans                                             &trans  &trans  &trans  &trans  &trans  &trans
    &trans  &kp EQUAL  &kp TILD  &kp HASH  &kp DLLR  &trans                                     &trans  &kp LT  &kp GT  &kp CARET  &trans  &trans
    &trans  &kp GRAVE  &kp MINUS  &trans  &kp BSLH  &kp PLUS                                    &trans  &kp LBKT  &kp RBKT  &kp PIPE  &kp FSLH  &trans
    &trans  &trans  &trans  &trans  &trans  &trans                                             &trans  &trans  &trans  &trans  &trans  &trans
                                        &none  &none  &none                                                                                     &none  &none  &none
                                                     &trans  &trans  &trans              &trans  &trans  &none
            >;
        };

        layer_Sym2 {
            bindings = <
    &trans  &trans  &trans  &trans  &trans  &trans                                             &trans  &trans  &trans  &trans  &trans  &trans
    &trans  &trans  &kp AT  &ht LA(LS(RBKT)) LA(RBKT)  &ht LA(LS(LBKT)) LA(LBKT)  &trans          &trans  &kp LPAR  &kp RPAR  &kp SEMI  &trans  &trans
    &trans  &kp STAR  &kp PRCNT  &ht QMARK EXCL  &kp DQT  &trans                                 &trans  &kp LBRC  &kp RBRC  &kp AMPS  &kp COLON  &trans
    &trans  &trans  &trans  &trans  &trans  &trans                                             &trans  &trans  &trans  &trans  &trans  &trans
                                        &none  &none  &none                                                                                     &none  &none  &none
                                                     &trans  &trans  &trans              &trans  &trans  &none
            >;
        };

        layer_FKeys {
            bindings = <
    &trans  &kp F1  &kp F2  &kp F3  &kp F4  &kp F5                                              &kp F6  &kp F7  &kp F8  &kp F9  &kp F10  &kp F11
    &trans  &trans  &kp BSPC  &kp UP  &trans  &trans                                            &trans  &trans  &kp UP  &kp BSPC  &trans  &kp F12
    &trans  &trans  &kp LEFT  &kp DOWN  &kp RIGHT  &kp RET                                       &trans  &kp LEFT  &kp DOWN  &kp RIGHT  &kp RET  &trans
    &trans  &trans  &trans  &trans  &trans  &trans                                              &trans  &trans  &trans  &trans  &trans  &trans
                                        &none  &none  &none                                                                                     &none  &none  &none
                                                     &trans  &kp LCTRL  &trans              &trans  &trans  &none
            >;
        };

        layer_Mouse {
            bindings = <
    &trans  &trans  &trans  &trans  &trans  &trans                                              &trans  &trans  &trans  &trans  &trans  &none
    &trans  &trans  &trans  &trans  &trans  &trans                                              &trans  &trans  &trans  &trans  &trans  &none
    &trans  &trans  &trans  &trans  &trans  &trans                                              &trans  &trans  &trans  &trans  &trans  &trans
    &trans  &trans  &trans  &trans  &trans  &trans                                              &trans  &trans  &trans  &trans  &trans  &none
                                        &none  &none  &none                                                                                     &none  &none  &none
                                                     &trans  &trans  &trans              &mkp LCLK  &mkp RCLK  &none
            >;
        };

        layer_Scroll {
            bindings = <
    &trans  &trans  &trans  &trans  &trans  &trans                                              &trans  &trans  &trans  &trans  &trans  &trans
    &trans  &trans  &trans  &trans  &trans  &trans                                              &trans  &trans  &trans  &trans  &trans  &trans
    &trans  &trans  &trans  &trans  &trans  &trans                                              &trans  &trans  &trans  &trans  &trans  &trans
    &trans  &trans  &trans  &trans  &trans  &trans                                              &trans  &trans  &trans  &trans  &trans  &trans
                                        &trans  &trans  &trans                                                                                  &trans  &trans  &trans
                                                     &trans  &trans  &trans              &trans  &trans  &trans
            >;
        };
    };
};

// Hold-to-scroll: while LAYER_Scroll is active (left spare thumb key held),
// the right trackpad -- your primary pointing hand -- reports scroll events
// instead of cursor movement, mirroring the Navigator's DRAG_SCROLL toggle.
&cirque_rh_listener {
    input-processors = <&zip_xy_scaler 3 1>;
    layer_scroll {
        layers = <LAYER_Scroll>;
        input-processors = <&zip_xy_to_scroll_mapper>, <&zip_xy_scaler 1 8>;
    };
};
